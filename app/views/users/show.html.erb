
<p>名前 : <%= @user.name %></p>
<p>メールアドレス : <%= @user.email %></p>
<p>プロフィール : <%= @user.profile %></p>

<% if @user.image.attached? %>
     <%= image_tag  @user.image, size: '250x200'%>
<% end %>

<% if current_user.id == @user.id %>
  <%= link_to "編集する", edit_user_registration_path %>
<% end %>

<h2>ユーザーの投稿一覧</h2>
<% @user.travels.each do |t| %>

      <% if t.user.image.attached? %>
     <%= image_tag  t.user.image, size: '250x200'%>
    <% end %>
       
   <% if t.image.attached? %>
            <%= image_tag url_for(t.image), size: '250x200'%>
   <% end %>
      <%= t.user.name %>
      <%= t.country_name %>
      <%= t.title %>
      <%= t.highlight %>
      <%= t.created_at %>
      <br>
<% end %>
<br>



<%= link_to "Tweet一覧に戻る", travels_path %>