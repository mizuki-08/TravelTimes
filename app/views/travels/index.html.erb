<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>スクロールで文字が消える</title>
<style>
  body {
    height: 2000px; /* スクロールできるように長めにする */
    background-color: #0d1116;
    color: white;
    margin: 0;
  }

  .fade-text {
    position: fixed; /* スクロールしても位置は固定 */
    top: 45%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-size: 60px;
    font-family: "Noto Serif JP", 游明朝, "Yu Mincho", YuMincho, "Hiragino Mincho Pro", serif;font-style: italic;
    transition: opacity 0.2s ease-out;
    pointer-events: none; /* クリックなどを無効にする */
  }
</style>
</head>
<body>
  <div class="fade-text">TRAVEL&TIMES</div>

  <script>
    const text = document.querySelector('.fade-text');
    window.addEventListener('scroll', () => {
      // スクロール量を取得（0〜1の範囲に正規化）
      const scrollY = window.scrollY;
      const maxScroll = 500; // どれくらいスクロールで消えるか調整
      const opacity = Math.max(1 - scrollY / maxScroll, 0);
      text.style.opacity = opacity;
    });
  </script>
</body>
</html>


